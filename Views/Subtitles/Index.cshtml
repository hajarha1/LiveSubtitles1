
@{
    Layout = null;
    ViewData["Title"] = "Live Subtitles";
}
<!DOCTYPE html>
<html>
<head>
    <title>Live Subtitles</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f0effe;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .app {
            width: 600px;
            padding: 2rem;
        }

        .header {
            text-align: center;
            margin-bottom: 2rem;
        }

            .header h1 {
                font-size: 22px;
                font-weight: 500;
                color: #26215C;
                margin-bottom: 4px;
            }

            .header p {
                font-size: 13px;
                color: #888;
            }

        .sub-box {
            background: #3C3489;
            border-radius: 16px;
            padding: 2rem;
            min-height: 130px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
        }

        .sub-text {
            font-size: 20px;
            color: #fff;
            font-weight: 500;
            text-align: center;
            margin-bottom: 12px;
        }

        .lang-badge {
            background: rgba(255,255,255,0.15);
            color: #fff;
            font-size: 12px;
            padding: 4px 14px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .status-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
            padding: 10px 14px;
            background: #fff;
            border-radius: 10px;
            border: 0.5px solid #ddd;
        }

        .status-left {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #555;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #639922;
        }

        .status-right {
            font-size: 12px;
            color: #aaa;
        }

        .btns {
            display: flex;
            gap: 12px;
        }

        .btn-start {
            flex: 1;
            padding: 12px;
            background: #26215C;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-start:hover {
                background: #3C3489;
            }

        .btn-stop {
            padding: 12px 20px;
            background: #fff;
            color: #555;
            border: 0.5px solid #ddd;
            border-radius: 10px;
            font-size: 15px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-stop:hover {
                background: #f5f5f5;
            }

        .dot-stopped {
            background: #aaa !important;
        }

        .dot-connecting {
            background: #EF9F27 !important;
        }

        .dot-live {
            background: #639922 !important;
        }

        .dot-error {
            background: #E24B4A !important;
        }
    </style>
</head>
<body>
    <div class="app">
        <div class="header">
            <h1>Live Subtitles</h1>
            <p>بث الترجمة الفورية المباشرة</p>
        </div>

        <div class="sub-box">
            <p class="sub-text" id="subtitle-text">اضغط ابدأ لتشغيل البث...</p>
            <span class="lang-badge">
                <i class="ti ti-world"></i>
                <span id="lang">-</span>
            </span>
        </div>

        <div class="status-bar">
            <div class="status-left">
                <span class="status-dot dot-stopped" id="status-dot"></span>
                <span id="status-text">متوقف</span>
            </div>
            <span class="status-right" id="counter"></span>
        </div>

        <div class="btns">
            <button class="btn-start" onclick="startStream()">
                ابدأ البث<i class="ti ti-player-play"></i>
            </button>
           @*  <button class="btn-stop" onclick="stopStream()">
                إيقاف <i class="ti ti-player-stop"></i>
            </button> *@
            <button class="btn-stop" onclick="stopStream()">
                <i class="ti ti-player-stop"></i> إيقاف
            </button>
        </div>
    </div>

    <script>
        let eventSource = null;
        let reconnectTimer = null;
        let lastIndex = 0;
        const total = 14;

        function setStatus(type, text) {
            const dot = document.getElementById('status-dot');
            dot.className = 'status-dot';
            if (type === 'live') dot.classList.add('dot-live');
            else if (type === 'connecting') dot.classList.add('dot-connecting');
            else if (type === 'error') dot.classList.add('dot-error');
            else dot.classList.add('dot-stopped');
            document.getElementById('status-text').textContent = text;
        }

        function detectLanguage(text) {
            const arabicPattern = /[\u0600-\u06FF]/;
            const frenchPattern = /[àâçéèêëîïôûùüÿœæ]/i;
            if (arabicPattern.test(text)) return "العربية";
            if (frenchPattern.test(text)) return "الفرنسية";
            return "الإنجليزية";
        }

        function startStream() {
            if (eventSource) eventSource.close();
            if (reconnectTimer) clearTimeout(reconnectTimer);

            setStatus('live', 'البث مباشر');
            eventSource = new EventSource(`/Subtitles/Stream?from=${lastIndex}`);

            eventSource.onmessage = function (e) {
                const data = JSON.parse(e.data);

                if (data.index === -1) {
                    eventSource.close();
                    lastIndex = 0;
                    setStatus('stopped', 'انتهى البث، اضغط ابدأ للتكرار');
                    document.getElementById('counter').textContent = '';
                    return;
                }

                lastIndex = data.index + 1;
                document.getElementById('subtitle-text').textContent = data.text;
                document.getElementById('lang').textContent = detectLanguage(data.text);
                document.getElementById('counter').textContent = `جملة ${lastIndex} / ${total}`;
            };

            eventSource.onerror = function () {
                setStatus('error', 'انقطع الاتصال... جاري إعادة الاتصال');
                eventSource.close();
                reconnectTimer = setTimeout(() => {
                    setStatus('connecting', 'جاري إعادة الاتصال...');
                    startStream();
                }, 3000);
            };
        }

        function stopStream() {
            if (eventSource) { eventSource.close(); eventSource = null; }
            if (reconnectTimer) { clearTimeout(reconnectTimer); reconnectTimer = null; }
            setStatus('stopped', 'متوقف');
        }
    </script>
</body>
</html>



































